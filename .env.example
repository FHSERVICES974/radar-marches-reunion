# ===== Publication Replit (option B : automatiser le redeploy) =====
# Laisser vide = option A (rappel de clic "Redeploy" manuel dans Deployments).
# Renseigner l'URL du Deploy Hook Replit = redeploy déclenché en HTTP POST.
REPLIT_DEPLOY_HOOK=

